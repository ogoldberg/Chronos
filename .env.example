# ─── AI Provider ───
# Choose your provider: anthropic, openai, google, ollama
AI_PROVIDER=anthropic
# AI_MODEL=claude-sonnet-4-20250514   # Override default model
# AI_BASE_URL=                         # For proxies, Azure, Ollama
# AI_WEB_SEARCH=true                   # Enable web search (Anthropic/OpenAI)
# AI_MAX_TOKENS=2000

# Provider-specific API keys (only need the one for your chosen provider)
ANTHROPIC_API_KEY=your_key_here
# OPENAI_API_KEY=your_key_here
# GOOGLE_AI_API_KEY=your_key_here
# OLLAMA_BASE_URL=http://localhost:11434

# ─── Database ───
# PostgreSQL (optional — app works without it using in-memory cache)
# DATABASE_URL=postgresql://localhost:5432/chronos

# ─── Server ───
# PORT=3000
