# ─── Chronos env template ─────────────────────────────────────────────
#
# None of these are strictly required — the app boots to a usable state
# with zero env vars. Fill them in to enable auth, persistence, and
# server-side event caching.
#
# AI features do NOT need anything here. Users bring their own keys via
# the in-app Settings panel (⌘K → "AI settings"). All AI traffic goes
# browser-direct to the provider; the server is never in the AI path.

# ─── Database (optional) ──────────────────────────────────────────────
# PostgreSQL. Required for Better Auth, persistent event caches, and
# classroom features. The app runs in-memory-only without it.
# DATABASE_URL=postgresql://localhost:5432/chronos

# ─── Authentication (optional) ────────────────────────────────────────
# Better Auth powers sign-in. Required only if you want user accounts.
# Generate a random 32+ byte string for AUTH_SECRET.
# AUTH_SECRET=
# BETTER_AUTH_URL=http://localhost:3000
# BASE_URL=http://localhost:3000

# OAuth providers (optional — set BOTH id and secret to enable)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ─── Server ───────────────────────────────────────────────────────────
# PORT=3000

# ─── Dev-only seed script ─────────────────────────────────────────────
# The `npm run seed` CLI warms the DB with AI-generated events for all
# zoom tiers. Runs only when you invoke it manually; never serves user
# traffic. Uses your Anthropic key since it runs in Node.
# ANTHROPIC_API_KEY=
# AI_MODEL=claude-sonnet-4-20250514

# ─── Public API gating (optional) ─────────────────────────────────────
# If set, /api/events and /api/search require this key in the X-API-Key
# header. Leave unset to keep the read-only public API open.
# CHRONOS_PUBLIC_API_KEY=
